# ------------------------------------------------------------------------------
# 数据库：使用 Supabase（托管 PostgreSQL）。无需在本机安装 PostgreSQL，
# 除非你要完全自建库并改写连接方式（当前代码走 Supabase API）。
#
# 在 https://supabase.com 创建项目后，控制台 → Project Settings → API：
#   - Project URL        → COZE_SUPABASE_URL
#   - anon public        → COZE_SUPABASE_ANON_KEY
#   - service_role       → COZE_SUPABASE_SERVICE_ROLE_KEY（仅服务端，勿暴露给浏览器）
# ------------------------------------------------------------------------------

COZE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
COZE_SUPABASE_ANON_KEY=your_supabase_anon_key
COZE_SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# 表结构同步（启动时与 pnpm db:push）：Dashboard → Project Settings → Database → Connection string → URI
# 将密码替换为创建项目时的数据库密码；URI 中特殊字符需 URL 编码。优先 Session/直连 5432（非 Pooler 6543）更利于 DDL。
COZE_DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# 设为 1 则跳过启动时的表结构同步
# COZE_SKIP_DB_PUSH=1

# 本地开发建议 DEV；生产部署可设为 PROD
COZE_PROJECT_ENV=DEV

# 自定义 Node 服务（scripts/start.sh / src/server.ts）监听地址与端口
HOSTNAME=localhost
PORT=5002

# ------------------------------------------------------------------------------
# 域账号登录（可选，不拦截页面）：配置后可访问 /login 写入会话；侧栏可显示当前用户。
# 未配置 AUTH_SECRET 时登录页会提示「未启用」。全站路由不强制登录。
# AUTH_SECRET=
# DOMAIN_LOGIN_PASSWORD=
# DOMAIN_ACCOUNT_SUFFIX=@corp.local
# NEXT_PUBLIC_DOMAIN_ACCOUNT_SUFFIX=@corp.local
# ------------------------------------------------------------------------------
